{
    "name": "optigov/fitconnect",
    "description": "Laravel package to communicate with ZBP via the FIT-Connect Backend",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "web-token/jwt-library": "^3.0",
        "symfony/uid": "^6.0|^7.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.27",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "OptiGov\\FitConnect\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OptiGov\\FitConnect\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OptiGov\\FitConnect\\FitConnectServiceProvider"
            ],
            "aliases": {
                "FitConnect": "OptiGov\\FitConnect\\Facades\\FitConnect"
            }
        }
    },
    "scripts": {
        "larastan-analyze": "php -d memory_limit=-1 vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
