{
    "name": "optigov/fitconnect",
    "description": "PHP package to communicate with ZBP via the FIT-Connect Submission API v2",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "ext-fileinfo": "*",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/uid": "^7.0",
        "web-token/jwt-library": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "OptiGov\\FitConnect\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OptiGov\\FitConnect\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan-analyse": "php -d memory_limit=-1 vendor/bin/phpstan analyse",
        "php-cs-fixer-fix": "php -d memory_limit=-1 vendor/bin/php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
